rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Listing images: any authenticated user can upload; anyone can read
    match /listing_images/{listingId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024  // 10 MB
                   && request.resource.contentType.matches('image/.*');
    }

    // Poster images: any authenticated user can upload; anyone can read
    match /posters/{listingId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
