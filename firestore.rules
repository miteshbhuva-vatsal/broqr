rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — any authenticated user can read profiles (needed for broker discovery);
    //         only the owning user may write their own document.
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /likes/{listingId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /views/{listingId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Listings — authenticated users can read; only the owner can write
    match /listings/{listingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.brokerUid == request.auth.uid;
      allow update: if request.auth != null
                    && (resource.data.brokerUid == request.auth.uid
                        || (request.resource.data.diff(resource.data).affectedKeys()
                              .hasOnly(['likesCount', 'viewsCount'])));
      allow delete: if request.auth != null
                    && resource.data.brokerUid == request.auth.uid;
    }

    // Connections
    match /connections/{connectionId} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants;
      allow update, delete: if request.auth != null
                            && request.auth.uid in resource.data.participants;
    }

    // Notifications
    match /notifications/{userId}/items/{notifId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Chats
    match /chats/{chatId} {
      allow read, update: if request.auth != null
                          && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        allow read: if request.auth != null
                    && request.auth.uid in
                       get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if request.auth != null
                      && request.resource.data.senderId == request.auth.uid
                      && request.auth.uid in
                         get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // Leads / CRM
    //   - Owner can read, update, delete their own leads.
    //   - Any authenticated user can CREATE a lead for any broker (needed for
    //     referral auto-lead flow where a new user triggers lead creation for
    //     the referring broker).
    match /leads/{leadId} {
      allow read, update, delete: if request.auth != null
                                  && resource.data.ownerUid == request.auth.uid;
      allow create: if request.auth != null;
    }

    // App events — analytics service writes app-open events.
    //   Only the user who generated the event may create it; no reads from client.
    match /appEvents/{eventId} {
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
    }

    // Categories — read-only from app (writes via Admin SDK only)
    match /categories/{catId} {
      allow read: if request.auth != null;
    }

    // Subscription plans — read-only from app
    match /subscriptionPlans/{planId} {
      allow read: if request.auth != null;
    }
  }
}
