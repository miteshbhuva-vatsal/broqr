rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — public read for broker profiles (shared via deep links);
    //         only the owning user may write their own document.
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;

      match /likes/{listingId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /views/{listingId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /inquiries/{listingId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Listings — public read (marketplace content, shared via deep links);
    //            only the owner can write.
    match /listings/{listingId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.brokerUid == request.auth.uid;
      allow update: if request.auth != null
                    && (resource.data.brokerUid == request.auth.uid
                        || (request.resource.data.diff(resource.data).affectedKeys()
                              .hasOnly(['likesCount', 'viewsCount', 'contactsCount'])));
      allow delete: if request.auth != null
                    && resource.data.brokerUid == request.auth.uid;
    }

    // Connections — supports legacy (participants[]) and current (followerId/followingId) format.
    // Connection records are immutable once created; only delete (unfollow) is allowed.
    match /connections/{connectionId} {
      allow read: if request.auth != null
                  && (request.auth.uid in resource.data.get('participants', [])
                      || resource.data.followerId == request.auth.uid
                      || resource.data.followingId == request.auth.uid);
      allow create: if request.auth != null
                    && (request.auth.uid in request.resource.data.get('participants', [])
                        || request.resource.data.followerId == request.auth.uid
                        || request.resource.data.followingId == request.auth.uid);
      allow update: if false;
      allow delete: if request.auth != null
                    && (request.auth.uid in resource.data.get('participants', [])
                        || resource.data.followerId == request.auth.uid
                        || resource.data.followingId == request.auth.uid);
    }

    // Connection requests — pending connect invitations between users.
    // Sender must be the authenticated user, cannot self-target, and request docs
    // are immutable (delete = cancel/decline; create-new = re-request).
    match /connection_requests/{requestId} {
      allow read: if request.auth != null
                  && (resource.data.senderId == request.auth.uid
                      || resource.data.receiverId == request.auth.uid);
      allow create: if request.auth != null
                    && request.resource.data.senderId == request.auth.uid
                    && request.resource.data.receiverId is string
                    && request.resource.data.senderId
                        != request.resource.data.receiverId;
      allow delete: if request.auth != null
                    && (resource.data.senderId == request.auth.uid
                        || resource.data.receiverId == request.auth.uid);
      allow update: if false;
    }

    // Notifications
    // Only the recipient may read, update (mark-read), or delete their items.
    // Any authenticated user may CREATE a notification for another user
    // (e.g. "new lead" written by the buyer, "new listing" by the seller).
    match /notifications/{userId}/items/{notifId} {
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null;
    }

    // Chats
    match /chats/{chatId} {
      allow read, update: if request.auth != null
                          && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
                    && request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        allow read: if request.auth != null
                    && request.auth.uid in
                       get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if request.auth != null
                      && request.resource.data.senderId == request.auth.uid
                      && request.auth.uid in
                         get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // Leads / CRM
    //   - Owner can read, update, delete their own leads.
    //   - Org members can read org leads (orgId set) if they belong to that org
    //     (checked via org_members collection by brokerUid + orgId).
    //   - Any authenticated user can CREATE a lead for any broker (needed for
    //     referral auto-lead flow + listing-contact auto-lead flow), but the
    //     payload is validated: ownerUid must be a string and source must be
    //     one of the known enum values. This blocks injection of arbitrary fields
    //     and forces clients through the documented entry points.
    match /leads/{leadId} {
      // Owner can always read/update/delete their own leads.
      allow read, update, delete: if request.auth != null
                                  && resource.data.ownerUid == request.auth.uid;

      // Org-scoped read: any active org member can read all org leads.
      allow read: if request.auth != null
                  && resource.data.get('orgId', null) != null
                  && exists(/databases/$(database)/documents/org_members/$(
                       request.auth.uid + '_' + resource.data.orgId))
                  && get(/databases/$(database)/documents/org_members/$(
                       request.auth.uid + '_' + resource.data.orgId)).data.isActive == true;

      // Org-scoped write: active members with role != 'view' can update/delete.
      allow update, delete: if request.auth != null
                  && resource.data.get('orgId', null) != null
                  && exists(/databases/$(database)/documents/org_members/$(
                       request.auth.uid + '_' + resource.data.orgId))
                  && get(/databases/$(database)/documents/org_members/$(
                       request.auth.uid + '_' + resource.data.orgId)).data.role != 'view'
                  && get(/databases/$(database)/documents/org_members/$(
                       request.auth.uid + '_' + resource.data.orgId)).data.isActive == true;

      // Create: 'contacted' source (listing-contact / referral flow) may be
      // written by any authenticated user against any broker.
      // 'added' source (CRM manual entry) must be written by the lead owner.
      // view-only org members are blocked from creating leads for their org.
      allow create: if request.auth != null
                    && request.resource.data.ownerUid is string
                    && request.resource.data.ownerUid.size() > 0
                    && (
                      !('source' in request.resource.data.keys())
                      || request.resource.data.source in ['added', 'contacted']
                    )
                    && (
                      request.resource.data.get('source', 'contacted') != 'added'
                      || request.resource.data.ownerUid == request.auth.uid
                    )
                    && (
                      request.resource.data.get('orgId', null) == null
                      || !exists(/databases/$(database)/documents/org_members/$(
                           request.auth.uid + '_' + request.resource.data.orgId))
                      || get(/databases/$(database)/documents/org_members/$(
                           request.auth.uid + '_' + request.resource.data.orgId)).data.role != 'view'
                    );
    }

    // App events — analytics service writes app-open events.
    //   Only the user who generated the event may create it; no reads from client.
    match /appEvents/{eventId} {
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
    }

    // Community posts (Ask tab) — public read (shared via deep links);
    // author owns the post. Counters bumped via field-scoped updates.
    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.authorUid == request.auth.uid;
      allow update: if request.auth != null
                    && (
                      // Author can update their own post freely.
                      resource.data.authorUid == request.auth.uid
                      // Anyone authed can bump only the counters by ±1.
                      || (
                        request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['likesCount', 'commentsCount'])
                      )
                    );
      allow delete: if request.auth != null
                    && resource.data.authorUid == request.auth.uid;

      // Per-user like flag. Doc id = liker uid; only that user may toggle it.
      match /likes/{uid} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      // Flat comments under each post. Author of the comment owns it.
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
                      && request.resource.data.authorUid == request.auth.uid;
        allow update: if false;
        allow delete: if request.auth != null
                      && resource.data.authorUid == request.auth.uid;
      }
    }

    // Localities — shared autocomplete dictionary; any signed-in user can read/write
    match /localities/{localityId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Categories — read-only from app (writes via Admin SDK only)
    match /categories/{catId} {
      allow read: if request.auth != null;
    }

    // Subscription plans — read-only from app
    match /subscriptionPlans/{planId} {
      allow read: if request.auth != null;
    }

    // ── Organisations ────────────────────────────────────────────────────────
    // Members read their own org; admin writes (create handled by Admin SDK / batch).
    match /organisations/{orgId} {
      allow read: if request.auth != null
                  && request.auth.uid != null;
      // Admin can update any field. Any authenticated user may increment/decrement
      // memberCount only — this is written by the acceptInvite batch when a new
      // member joins and the joining user is not yet the org admin.
      allow update: if request.auth != null
                    && (
                      resource.data.adminUid == request.auth.uid
                      || request.resource.data.diff(resource.data)
                             .affectedKeys().hasOnly(['memberCount'])
                    );
      allow create: if request.auth != null;
    }

    // ── Org members ──────────────────────────────────────────────────────────
    match /org_members/{memberId} {
      // Any authenticated user can read members (org directory).
      allow read: if request.auth != null;
      // Creates happen in the acceptInvite batch — any authed user may create
      // their own member record (the invite token is validated in the batch).
      allow create: if request.auth != null
                    && request.resource.data.brokerUid == request.auth.uid;
      // Updates (role change, deactivation): org admin only, or member
      // deactivating themselves (isActive → false, no other field changes).
      allow update: if request.auth != null
                    && (
                      // Org admin can update any member in the same org.
                      get(/databases/$(database)/documents/org_members/$(
                            request.auth.uid + '_' + resource.data.orgId
                          )).data.role == 'admin'
                      && get(/databases/$(database)/documents/org_members/$(
                            request.auth.uid + '_' + resource.data.orgId
                          )).data.isActive == true
                      // Member may only deactivate themselves (no role changes).
                      || (
                        resource.data.brokerUid == request.auth.uid
                        && request.resource.data.diff(resource.data)
                               .affectedKeys().hasOnly(['isActive'])
                        && request.resource.data.isActive == false
                      )
                    );
      allow delete: if false;
    }

    // ── Lead activity log (subcollection) ────────────────────────────────────
    match /leads/{leadId}/activity/{actId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ── Org teams ────────────────────────────────────────────────────────────
    match /org_teams/{teamId} {
      allow read: if request.auth != null;
      // Create: use request.resource (resource is null on create).
      allow create: if request.auth != null
                    && get(/databases/$(database)/documents/org_members/$(
                             request.auth.uid + '_' + request.resource.data.orgId
                           )).data.role in ['admin', 'manager']
                    && get(/databases/$(database)/documents/org_members/$(
                             request.auth.uid + '_' + request.resource.data.orgId
                           )).data.isActive == true;
      // Update/delete: use resource (existing document).
      allow update, delete: if request.auth != null
                    && get(/databases/$(database)/documents/org_members/$(
                             request.auth.uid + '_' + resource.data.orgId
                           )).data.role in ['admin', 'manager']
                    && get(/databases/$(database)/documents/org_members/$(
                             request.auth.uid + '_' + resource.data.orgId
                           )).data.isActive == true;

      // Subcollection is named 'team_members' in the app.
      match /team_members/{memberId} {
        allow read: if request.auth != null;
        // Create: orgId is stored in the new document payload.
        allow create: if request.auth != null
                      && get(/databases/$(database)/documents/org_members/$(
                               request.auth.uid + '_' + request.resource.data.orgId
                             )).data.role in ['admin', 'manager']
                      && get(/databases/$(database)/documents/org_members/$(
                               request.auth.uid + '_' + request.resource.data.orgId
                             )).data.isActive == true;
        // Delete: orgId is stored in the existing document.
        allow delete: if request.auth != null
                      && get(/databases/$(database)/documents/org_members/$(
                               request.auth.uid + '_' + resource.data.orgId
                             )).data.role in ['admin', 'manager']
                      && get(/databases/$(database)/documents/org_members/$(
                               request.auth.uid + '_' + resource.data.orgId
                             )).data.isActive == true;
      }
    }

    // ── Org invites ──────────────────────────────────────────────────────────
    match /org_invites/{inviteId} {
      // Pending invites are readable to look up by token during accept flow.
      allow read: if request.auth != null;
      // Only admin or manager of the org may create invites.
      allow create: if request.auth != null
                    && exists(/databases/$(database)/documents/org_members/$(
                         request.auth.uid + '_' + request.resource.data.orgId))
                    && get(/databases/$(database)/documents/org_members/$(
                         request.auth.uid + '_' + request.resource.data.orgId)).data.role in ['admin', 'manager']
                    && get(/databases/$(database)/documents/org_members/$(
                         request.auth.uid + '_' + request.resource.data.orgId)).data.isActive == true;
      // Only status updates (accept / revoke) allowed.
      allow update: if request.auth != null
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['status']);
      allow delete: if false;
    }
  }
}
